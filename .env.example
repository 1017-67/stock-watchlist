FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Optional frontend API base for Windows/preview mode.
# This is not a secret. Leave empty unless /api proxy is unavailable.
VITE_API_BASE_URL=http://127.0.0.1:8787

# Optional server-side Lunaris AI bridge.
# Keep these on the server. Never paste Codex/OpenAI keys into the browser.
LUNARIS_AI_PROVIDER=auto
LUNARIS_CODEX_CLI=codex
LUNARIS_CODEX_MODEL=gpt-5.5

# Optional portable HTTP fallback for machines without Codex CLI, such as Windows.
# Use either Lunaris-compatible values or OpenAI-compatible values.
LUNARIS_AI_API_KEY=
LUNARIS_AI_BASE_URL=https://api.openai.com/v1
LUNARIS_AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
